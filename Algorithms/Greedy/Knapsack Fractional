#include <stdio.h>

int main() {
    int n, i, j;
    float p[20], w[20], ratio[20];
    float M, temp, profit = 0;
    printf("Enter number of objects: ");
    scanf("%d", &n);
    for(i = 0; i < n; i++) {
        printf("Enter profit and weight of object %d: ", i + 1);
        scanf("%f %f", &p[i], &w[i]);
        ratio[i] = p[i] / w[i];
    }

    printf("Enter capacity of knapsack: ");
    scanf("%f", &M);
    for(i = 0; i < n - 1; i++) {
        int max = i;
        for(j = i + 1; j < n; j++) {
            if(ratio[j] > ratio[max]) {
                max = j;
            }
        }
        temp = ratio[i];
        ratio[i] = ratio[max];
        ratio[max] = temp;
        temp = p[i];
        p[i] = p[max];
        p[max] = temp;
        temp = w[i];
        w[i] = w[max];
        w[max] = temp;
    }
    for(i = 0; i < n; i++) {
        if(w[i] <= M) {
            profit = profit + p[i];
            M = M - w[i];
        }
        else {
            profit = profit + p[i] * (M / w[i]);
            break;
        }
    }
    printf("Maximum Profit = %.2f", profit);
    return 0;
}
